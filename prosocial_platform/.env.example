DJANGO_SETTINGS_MODULE=config.settings.development
DJANGO_SECRET_KEY=change-me-in-production
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

POSTGRES_DB=prosocial
POSTGRES_USER=prosocial
POSTGRES_PASSWORD=prosocial
POSTGRES_HOST=db
POSTGRES_PORT=5432

DATABASE_URL=postgres://prosocial:prosocial@db:5432/prosocial

# Shared cache for rate limiting and shell context (production). Optional in dev.
REDIS_URL=redis://redis:6379/0
